<?xml version="1.0" encoding="UTF-8"?>
<ids xmlns="http://standards.buildingsmart.org/IDS" xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://standards.buildingsmart.org/IDS http://standards.buildingsmart.org/IDS/1.0/ids.xsd">
  <info>
    <title>UBS Porte 1 - Basic Requirements</title>
    <version>1.0</version>
    <description>Basic information delivery requirements for UBS Porte 1.</description>
  </info>
  <specifications>
    <specification name="Walls must have material" ifcVersion="IFC2X3">
      <applicability minOccurs="1" maxOccurs="unbounded">
        <entity>
          <name>
            <simpleValue>IFCWALLSTANDARDCASE</simpleValue>
          </name>
        </entity>
      </applicability>
      <requirements>
        <material cardinality="required"/>
      </requirements>
    </specification>
    <specification name="Doors must have material" ifcVersion="IFC2X3">
      <applicability minOccurs="1" maxOccurs="unbounded">
        <entity>
          <name>
            <simpleValue>IFCDOOR</simpleValue>
          </name>
        </entity>
      </applicability>
      <requirements>
        <material cardinality="required"/>
      </requirements>
    </specification>
    <specification name="Slabs must have material" ifcVersion="IFC2X3">
      <applicability minOccurs="1" maxOccurs="unbounded">
        <entity>
          <name>
            <simpleValue>IFCSLAB</simpleValue>
          </name>
        </entity>
      </applicability>
      <requirements>
        <material cardinality="required"/>
      </requirements>
    </specification>
  </specifications>
</ids>
